{
  "manifest_version": 3,
  "name": "摸鱼图片视频遮罩",
  "description": "在指定网站中将图片和视频替换为跟随深浅色模式的纯色块。",
  "version": "0.1.0",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "https://www.xiaohongshu.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
